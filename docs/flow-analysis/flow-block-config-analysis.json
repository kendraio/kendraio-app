                                    "title": "City"
                                },
                                "country": {
                                    "type": "string",
                                    "title": "Country"
                                },
                                "latitude": {
                                    "type": "string",
                                    "title": "Latitude"
                                },
                                "longitude": {
                                    "type": "string",
                                    "title": "Longitude"
                                }
                            }
                        },
                        "uiSchema": {},
                        "blockComment": ""
                    }
                }
            ]
        }
